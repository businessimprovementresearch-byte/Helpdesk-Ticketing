# === Umum ===
PRODUCTION=False
DEBUG=True
SECRET_KEY=ganti-dengan-random-string-panjang
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# === Database (Supabase Postgres) — hanya dipakai kalau PRODUCTION=True ===
DB_NAME=postgres
DB_USER=postgres.xxxxxxxxxxxx
DB_PASSWORD=
DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
DB_PORT=5432
SCHEMA=public

# === Supabase Storage (S3-compatible) — kosongkan saat dev, fallback ke local media/ ===
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_BUCKET=attachments
SUPABASE_S3_ENDPOINT_URL=https://xxxxxxxxxxxx.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-southeast-1

# === Email keluar (SMTP Zoho) — kosongkan saat dev, fallback ke console backend ===
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# === Email masuk (IMAP Gmail) — dipakai oleh `python manage.py fetch_emails` ===
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USE_SSL=True
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
